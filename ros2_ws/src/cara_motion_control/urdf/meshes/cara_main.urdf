<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cara">

  <link name="torso">
    <visual>
      <geometry><mesh filename="package://cara_motion_control/urdf/meshes/torso.obj"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.12 0.2"/> </geometry>
    </collision>
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 -0.05"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <link name="thigh_l">
    <visual>
      <geometry><mesh filename="package://cara_motion_control/urdf/meshes/thigh_l.obj"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.1"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 -0.05"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="head_link">
    <visual>
      <geometry><mesh filename="package://cara_motion_control/urdf/meshes/head.obj"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.08"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  </robot>
