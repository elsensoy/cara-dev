<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cara">

  <xacro:property name="lower_torso_mass" value="1.0" /> <xacro:property name="upper_torso_mass" value="0.8" /> <xacro:property name="leg_mass"         value="0.2" />
  <xacro:property name="gimbal_mass"      value="0.05" />

  <material name="bear_brown"> <color rgba="0.45 0.3 0.2 1.0"/> </material>

  <link name="base_link"/>

  <link name="lower_torso">
    <inertial>
      <mass value="${lower_torso_mass}"/>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005"/>
    </inertial>
    <visual>
      <geometry><box size="0.12 0.15 0.1"/></geometry>
      <material name="bear_brown"/>
    </visual>
    <collision>
      <geometry><box size="0.12 0.15 0.1"/></geometry>
    </collision>
  </link>

  <joint name="base_to_lower" type="fixed">
    <parent link="base_link"/>
    <child link="lower_torso"/>
  </joint>

  <xacro:macro name="cara_leg" params="prefix side_sign">
    <link name="thigh_${prefix}">
      <inertial>
        <mass value="${leg_mass}"/>
        <origin xyz="0 0 -0.05"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="0.02" length="0.1"/></geometry>
      </visual>
      <collision>
        <geometry><cylinder radius="0.02" length="0.1"/></geometry>
      </collision>
    </link>

    <joint name="hip_pitch_${prefix}" type="revolute">
      <parent link="lower_torso"/>
      <child link="thigh_${prefix}"/>
      <origin xyz="0.0 ${side_sign * 0.08} -0.05" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.0" upper="1.0" effort="3.0" velocity="6.0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:cara_leg prefix="l" side_sign="1" />
  <xacro:cara_leg prefix="r" side_sign="-1" />

  <link name="waist_intermediate">
    <inertial>
      <mass value="${gimbal_mass}"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="waist_yaw" type="revolute">
    <parent link="lower_torso"/>
    <child link="waist_intermediate"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.78" upper="0.78" effort="2.0" velocity="4.0"/>
  </joint>

  <link name="upper_torso">
    <inertial>
      <mass value="${upper_torso_mass}"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/> 
      <inertia ixx="0.008" iyy="0.008" izz="0.006"/>
    </inertial>
    <visual>
      <geometry><box size="0.1 0.12 0.15"/></geometry>
      <material name="bear_brown"/>
    </visual>
    <collision>
      <geometry><box size="0.1 0.12 0.15"/></geometry>
    </collision>
  </link>

  <joint name="waist_pitch" type="revolute">
    <parent link="waist_intermediate"/>
    <child link="upper_torso"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.78" upper="0.78" effort="3.5" velocity="4.0"/>
  </joint>

</robot>
